# The OddsAPI free tier (https://the-odds-api.com). 500 requests per month.
# Sign up, paste your key here. Without this key the app falls back to a static
# placeholder slate so the UI still renders.
ODDS_API_KEY=

# Anthropic API key (https://console.anthropic.com). Used to generate the plain
# English reasoning paragraph per prop. Roughly $0.01 per game per refresh.
# Without this key the UI shows the structured factor breakdown only.
ANTHROPIC_API_KEY=

# Secret used to gate the Vercel cron handler. Generate any random string.
CRON_SECRET=

# Public site URL, used for OG tags and share links. No trailing slash.
NEXT_PUBLIC_SITE_URL=https://nba-playoff-props.vercel.app
