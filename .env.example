# The OddsAPI free tier (https://the-odds-api.com). 500 requests per month.
# Sign up, paste your key here. Without this key the app falls back to a static
# placeholder slate so the UI still renders.
ODDS_API_KEY=

# Groq API key (https://console.groq.com). Free tier covers Llama 3.3 70B with
# generous daily token limits. Used to generate the plain English reasoning
# paragraph per prop. Without this key (or when the daily limit is hit) the
# UI shows a deterministic templated paragraph built from the same factors.
GROQ_API_KEY=

# Optional. Override the default model.
GROQ_MODEL=llama-3.3-70b-versatile

# Secret used to gate the Vercel cron handler. Generate any random string.
CRON_SECRET=

# Public site URL, used for OG tags and share links. No trailing slash.
NEXT_PUBLIC_SITE_URL=https://nba-playoff-props.vercel.app
